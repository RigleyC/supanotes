# SupaNotes backend — env vars (development).
#
# Copy to `.env` and adjust. Never commit `.env`.

# Server
PORT=8080
ENVIRONMENT=dev

# Database (PostgreSQL 16 + pgvector)
DATABASE_URL=postgres://supanotes:supanotes@localhost:5432/supanotes?sslmode=disable

# Auth (HS256 — must be 32+ bytes outside dev)
JWT_SECRET=change-me-in-production-to-a-long-random-string

# CORS (comma-separated origins; defaults to * in dev, empty in prod)
CORS_ORIGINS=*

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Embeddings (defaults: api.openai.com, text-embedding-3-small)
OPENAI_EMBEDDINGS_API_KEY=
OPENAI_EMBEDDINGS_MODEL=

# OpenAI-compatible provider for inbox-organize (default: api.openai.com).
# Override BASE_URL to point at any /chat/completions-compatible API:
#   - OpenAI:        https://api.openai.com/v1/chat/completions
#   - Groq:          https://api.groq.com/openai/v1/chat/completions
#   - OpenRouter:    https://openrouter.ai/api/v1/chat/completions
#   - Together:      https://api.together.xyz/v1/chat/completions
# Override MODEL with any model the chosen provider exposes.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=

# Notifications — Firebase Cloud Messaging (service account JSON)
FCM_CREDENTIALS_FILE=

# Telegram gateway (bot token from @BotFather)
TELEGRAM_BOT_TOKEN=
