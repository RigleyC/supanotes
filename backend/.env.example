# SupaNotes backend — env vars (development).
#
# Copy to `.env` and adjust. Never commit `.env`.

# Server
PORT=8080
ENVIRONMENT=dev

# Database (PostgreSQL 16)
DATABASE_URL=postgres://supanotes:supanotes@localhost:5432/supanotes?sslmode=disable

# Auth (HS256 — must be 32+ bytes outside dev)
JWT_SECRET=change-me-in-production-to-a-long-random-string

# CORS (comma-separated origins; defaults to * in dev, empty in prod)
CORS_ORIGINS=*

# S3-compatible object storage (AWS, MinIO, Supabase, GCS)
# Leave S3_BUCKET empty to run without storage (dev only).
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=supanotes-attachments
S3_ACCESS_KEY_ID=your_key_here
S3_SECRET_ACCESS_KEY=your_secret_here
S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com
