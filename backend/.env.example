# SupaNotes backend — env vars (development).
#
# Copy to `.env` and adjust. Never commit `.env`.

# Server
PORT=8080
ENVIRONMENT=dev

# Database (PostgreSQL 16 + pgvector)
DATABASE_URL=postgres://supanotes:supanotes@localhost:5432/supanotes?sslmode=disable

# Auth (HS256 — must be 32+ bytes outside dev)
JWT_SECRET=change-me-in-production-to-a-long-random-string

# CORS (comma-separated origins; defaults to * in dev, empty in prod)
CORS_ORIGINS=*

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Notifications — Firebase Cloud Messaging (service account JSON)
FCM_CREDENTIALS_FILE=

# Telegram gateway (bot token from @BotFather)
TELEGRAM_BOT_TOKEN=
