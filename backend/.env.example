# SupaNotes backend — env vars (development).
#
# Copy to `.env` and adjust. Never commit `.env`.

# Server
PORT=8080
ENVIRONMENT=dev

# Database (PostgreSQL 16 + pgvector)
DATABASE_URL=postgres://supanotes:supanotes@localhost:5432/supanotes?sslmode=disable

# Auth (HS256 — must be 32+ bytes outside dev)
JWT_SECRET=change-me-in-production-to-a-long-random-string

# CORS (comma-separated origins; defaults to * in dev, empty in prod)
CORS_ORIGINS=*

# ──────────────────────────────────────
# AI — each feature independently configurable.
# Set BASE_URL to any OpenAI /chat/completions-compatible API:
#   OpenAI:     https://api.openai.com/v1/chat/completions
#   Groq:       https://api.groq.com/openai/v1/chat/completions
#   OpenRouter: https://openrouter.ai/api/v1/chat/completions
#   Together:   https://api.together.xyz/v1/chat/completions
#   DeepSeek:   https://api.deepseek.com/v1/chat/completions
# ──────────────────────────────────────

# Agent chat (default: Anthropic Claude).
# Leave AGENT_BASE_URL empty to keep using Anthropic directly.
AGENT_BASE_URL=
AGENT_MODEL=                          # default: gpt-4o (when BASE_URL set)
AGENT_API_KEY=                        # fallback: ANTHROPIC_API_KEY

# Brief generation / routines (default: DeepSeek deepseek-chat)
BRIEF_BASE_URL=
BRIEF_MODEL=                          # default: deepseek-chat

# Inbox organize (default: OpenAI gpt-4o-mini)
ORGANIZE_BASE_URL=
ORGANIZE_MODEL=                       # default: gpt-4o-mini

# Embeddings — semantic search, RAG, memories (default: OpenAI)
# Uses /embeddings endpoint, not /chat/completions.
EMBEDDINGS_BASE_URL=                  # default: https://api.openai.com/v1/embeddings
EMBEDDINGS_MODEL=                     # default: text-embedding-3-small

# ── API keys ──
ANTHROPIC_API_KEY=                    # agent chat (fallback for AGENT_API_KEY)
DEEPSEEK_API_KEY=                     # briefs
OPENAI_API_KEY=                       # inbox organize
OPENAI_EMBEDDINGS_API_KEY=            # embeddings

# Embeddings cron (every 30s by default)
EMBEDDINGS_CRON_INTERVAL=*/30 * * * * *

# Legacy vars (still read as fallbacks for ORGANIZE_* and EMBEDDINGS_MODEL)
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_MODEL=
# OPENAI_EMBEDDINGS_MODEL=

# Notifications — Firebase Cloud Messaging (service account JSON)
FCM_CREDENTIALS_FILE=

# Telegram gateway (bot token from @BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram webhook secret token (optional — set in bot settings for extra security)
TELEGRAM_WEBHOOK_SECRET=
