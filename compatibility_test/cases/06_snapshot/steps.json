{
  "name": "Snapshot capture and restore",
  "clients": [
    "A",
    "B"
  ],
  "steps": [
    {
      "client": "A",
      "action": "text_insert",
      "name": "note",
      "index": 0,
      "value": "Hello"
    },
    {
      "client": "A",
      "action": "take_snapshot",
      "id": "snap1"
    },
    {
      "client": "A",
      "action": "text_delete",
      "name": "note",
      "index": 2,
      "length": 3
    },
    {
      "client": "B",
      "action": "restore_snapshot",
      "source_client": "A",
      "snapshot_id": "snap1"
    }
  ],
  "expected": {
    "text": {
      "note": "Hello"
    }
  }
}