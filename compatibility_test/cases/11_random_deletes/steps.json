{
  "name": "Random concurrent deletes simulation",
  "clients": [
    "A",
    "B"
  ],
  "steps": [
    {
      "client": "A",
      "action": "text_insert",
      "name": "note",
      "index": 0,
      "value": "0123456789ABCDEF"
    },
    {
      "client": "A",
      "action": "export_update",
      "id": "u1"
    },
    {
      "client": "B",
      "action": "import_update",
      "id": "u1"
    },
    {
      "client": "A",
      "action": "text_delete",
      "name": "note",
      "index": 1,
      "length": 2
    },
    {
      "client": "A",
      "action": "text_delete",
      "name": "note",
      "index": 5,
      "length": 3
    },
    {
      "client": "A",
      "action": "export_update",
      "id": "u2"
    },
    {
      "client": "B",
      "action": "text_delete",
      "name": "note",
      "index": 13,
      "length": 2
    },
    {
      "client": "B",
      "action": "text_delete",
      "name": "note",
      "index": 8,
      "length": 3
    },
    {
      "client": "B",
      "action": "export_update",
      "id": "u3"
    },
    {
      "client": "A",
      "action": "import_update",
      "id": "u3"
    },
    {
      "client": "B",
      "action": "import_update",
      "id": "u2"
    }
  ],
  "expected": {
    "text": {
      "note": "03456BCF"
    }
  }
}