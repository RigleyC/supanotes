{
  "name": "Snapshot restore with peer offline modifications",
  "clients": [
    "A",
    "B",
    "C"
  ],
  "steps": [
    {
      "client": "A",
      "action": "text_insert",
      "name": "note",
      "index": 0,
      "value": "Base"
    },
    {
      "client": "A",
      "action": "export_update",
      "id": "u1"
    },
    {
      "client": "B",
      "action": "import_update",
      "id": "u1"
    },
    {
      "client": "C",
      "action": "import_update",
      "id": "u1"
    },
    {
      "client": "A",
      "action": "text_insert",
      "name": "note",
      "index": 4,
      "value": " + OnlineA"
    },
    {
      "client": "A",
      "action": "take_snapshot",
      "id": "snapA"
    },
    {
      "client": "C",
      "action": "text_insert",
      "name": "note",
      "index": 4,
      "value": " + OfflineC"
    },
    {
      "client": "B",
      "action": "restore_snapshot",
      "source_client": "A",
      "snapshot_id": "snapA"
    },
    {
      "client": "B",
      "action": "export_update",
      "id": "uB_snap"
    },
    {
      "client": "C",
      "action": "import_update",
      "id": "uB_snap"
    },
    {
      "client": "C",
      "action": "export_update",
      "id": "uC_edits"
    },
    {
      "client": "A",
      "action": "import_update",
      "id": "uC_edits"
    }
  ],
  "expected": {
    "text": {
      "note": "Base + OfflineC + OnlineA"
    }
  }
}