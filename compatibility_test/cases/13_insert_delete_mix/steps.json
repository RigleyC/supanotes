{
  "name": "Concurrent Insert and Delete mix",
  "clients": [
    "A",
    "B"
  ],
  "steps": [
    {
      "client": "A",
      "action": "text_insert",
      "name": "note",
      "index": 0,
      "value": "ABCDEF"
    },
    {
      "client": "A",
      "action": "export_update",
      "id": "u1"
    },
    {
      "client": "B",
      "action": "import_update",
      "id": "u1"
    },
    {
      "client": "A",
      "action": "text_insert",
      "name": "note",
      "index": 3,
      "value": "xyz"
    },
    {
      "client": "A",
      "action": "text_delete",
      "name": "note",
      "index": 0,
      "length": 2
    },
    {
      "client": "A",
      "action": "export_update",
      "id": "u2"
    },
    {
      "client": "B",
      "action": "text_delete",
      "name": "note",
      "index": 4,
      "length": 2
    },
    {
      "client": "B",
      "action": "text_insert",
      "name": "note",
      "index": 2,
      "value": "123"
    },
    {
      "client": "B",
      "action": "export_update",
      "id": "u3"
    },
    {
      "client": "A",
      "action": "import_update",
      "id": "u3"
    },
    {
      "client": "B",
      "action": "import_update",
      "id": "u2"
    }
  ],
  "expected": {
    "text": {
      "note": "C123xyzD"
    }
  }
}