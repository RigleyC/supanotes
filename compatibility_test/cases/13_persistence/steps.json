{
  "name": "Full document persistence backup & restore",
  "clients": [
    "A",
    "B"
  ],
  "steps": [
    {
      "client": "A",
      "action": "text_insert",
      "name": "note",
      "index": 0,
      "value": "Saved State"
    },
    {
      "client": "A",
      "action": "export_update",
      "id": "u1"
    },
    {
      "client": "B",
      "action": "import_update",
      "id": "u1"
    },
    {
      "client": "B",
      "action": "text_insert",
      "name": "note",
      "index": 11,
      "value": " - Loaded"
    },
    {
      "client": "B",
      "action": "export_update",
      "id": "u2"
    },
    {
      "client": "A",
      "action": "import_update",
      "id": "u2"
    }
  ],
  "expected": {
    "text": {
      "note": "Saved State - Loaded"
    }
  }
}