{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "flutter-dev",
            "type": "shell",
            "command": "flutter",
            "args": [
                "run"
            ],
            "cwd": "${workspaceFolder}",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Flutter.*",
                    "endsPattern": "^.*Application finished.*"
                }
            }
        },
        {
            "label": "flutter-stop",
            "type": "shell",
            "command": "pkill",
            "args": [
                "-f",
                "flutter"
            ],
            "cwd": "${workspaceFolder}",
            "windows": {
                "command": "taskkill",
                "args": [
                    "/F",
                    "/IM",
                    "flutter.exe"
                ]
            }
        },
        {
            "label": "Backend (Go)",
            "type": "shell",
            "command": "go",
            "args": [
                "run",
                "./cmd/server"
            ],
            "cwd": "${workspaceFolder}/backend",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*listening.*",
                    "endsPattern": "^.*$"
                }
            }
        }
    ]
}