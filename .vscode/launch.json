{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend (Go Server)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/cmd/server",
            "env": {
                "PORT": "8080",
                "DATABASE_URL": "postgres://supanotes:supanotes@localhost:5432/supanotes?sslmode=disable",
                "PATH": "C:\\Users\\rigleyc\\go\\bin;${env:PATH}"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "logOutput": "rpc"
        },
        {
            "name": "Frontend (Flutter)",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/lib/main.dart",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "setup-dev-env",
            "args": [
                "--dart-define-from-file=${workspaceFolder}/.vscode/.dart-define.json"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Backend + Frontend (Compound)",
            "preLaunchTask": "setup-dev-env",
            "postDebugTask": "flutter-stop",
            "configurations": [
                "Backend (Go Server)",
                "Frontend (Flutter)"
            ]
        }
    ]
}
