{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend (Go Server)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/cmd/server",
            "env": {
                "PORT": "8080",
                "DATABASE_URL": "postgres://supanotes:supanotes@localhost:5432/supanotes?sslmode=disable",
                "PATH": "C:\\Users\\rigleyc\\go\\bin;C:\\Users\\rigleyc\\go-sdk\\bin;${env:PATH}"
            },
            "cwd": "${workspaceFolder}/backend",
            "console": "internalConsole",
            "logOutput": "rpc"
        },
        {
            "name": "Frontend (Flutter - Selected Device/Desktop)",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/lib/main.dart",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "--dart-define-from-file=${workspaceFolder}/.vscode/.dart-define.local.json"
            ]
        },
        {
            "name": "Frontend (Flutter - Selected Emulator)",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/lib/main.dart",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "--dart-define-from-file=${workspaceFolder}/.vscode/.dart-define.emulator.json"
            ]
        },
        {
            "name": "Frontend (Flutter - Prod Backend)",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/lib/main.dart",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "--dart-define-from-file=${workspaceFolder}/.vscode/.dart-define.prod.json"
            ]
        }
    ],
    "compounds": [
        {
            "name": "SupaNotes Dev (Device/Desktop)",
            "preLaunchTask": "dev:prepare",
            "configurations": [
                "Backend (Go Server)",
                "Frontend (Flutter - Selected Device/Desktop)"
            ]
        },
        {
            "name": "SupaNotes Dev (Emulator)",
            "preLaunchTask": "dev:prepare",
            "configurations": [
                "Backend (Go Server)",
                "Frontend (Flutter - Selected Emulator)"
            ]
        }
    ]
}
